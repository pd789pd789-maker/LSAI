# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for generating realistic style images using DALL-E or gpt-image models.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# Optional: Override base URLs if not using default Google/OpenAI endpoints
# GEMINI_BASE_URL="https://api.apimart.ai" 
# OPENAI_BASE_URL="https://api.apimart.ai/v1"
# OPENAI_MODEL="gpt-image-2" 

# MONGODB_URI: MongoDB连接URI。配置后会启用用户登录功能和积分扣除机制。
MONGODB_URI="mongodb://username:password@your-db-host:27017/dbname"

# JWT_SECRET: 用于用户校验签名的密钥（如果不提供，默认使用 AI Studio 的临时密钥）
# JWT_SECRET="your-secure-jwt-secret"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
